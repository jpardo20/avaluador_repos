{
    "config": {
        "default_points": 1.0,
        "default_structure_penalty": 0.25,
        "allow_partial_credit": true
    },

    "rules": {

        "EV_ANALISI": {
            "nom": "Anàlisi del muntatge",
            "criteri": "Document d'anàlisi inicial del muntatge del sistema.",
            "max_score": 2.0,
            "ra_pes": {
                "RA1": 2.0
            },
            "expected_files": [
                "0221_muntatge/analisi.md"
            ],
            "extensions": [".md"]
        },

        "EV_DIAGNOSTIC": {
            "nom": "Diagnòstic",
            "criteri": "Diagnòstic dels problemes detectats durant el muntatge.",
            "max_score": 2.0,
            "ra_pes": {
                "RA2": 2.0
            },
            "expected_files": [
                "0221_muntatge/diagnostic.md"
            ],
            "extensions": [".md"]
        },

        "EV_VERIFICACIO": {
            "nom": "Verificació",
            "criteri": "Comprovació del funcionament correcte del sistema.",
            "max_score": 2.0,
            "ra_pes": {
                "RA2": 1.0,
                "RA3": 1.0
            },
            "expected_files": [
                "0221_muntatge/verificacio.md",
                "0221_muntatge/verificació.md"
            ],
            "extensions": [".md"]
        },

        "EV_CORRECCIO": {
            "nom": "Informe de correcció",
            "criteri": "Informe final amb les correccions aplicades.",
            "max_score": 2.0,
            "ra_pes": {
                "RA3": 2.0
            },
            "expected_files": [
                "correccio.md"
            ],
            "extensions": [".md"],
            "structure_penalty": 0.0
        },

        "EV_README": {
            "nom": "Documentació README",
            "criteri": "README del repositori amb la descripció del projecte.",
            "max_score": 1.0,
            "ra_pes": {
                "RA4": 1.0
            },
            "expected_files": [
                "README.md"
            ],
            "extensions": [".md"],
            "structure_penalty": 0.0
        },

        "EV_ENUNCIAT": {
            "nom": "Enunciat del treball",
            "criteri": "Document original de l'enunciat lliurat amb el treball.",
            "max_score": 1.0,
            "ra_pes": {
                "RA4": 1.0
            },
            "expected_files": [
                "fitxers/*.docx"
            ],
            "extensions": [".docx"]
        }

    }
}